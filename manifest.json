{
  "manifest_version": 3,
  "name": "Privacy Bulk Actions for Caflou",
  "version": "0.2.5",
  "description": "Rozšíření pro hromadnou správu práv a soukromí v systému Caflou.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.caflou.cz/*",
        "*://*.caflou.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
